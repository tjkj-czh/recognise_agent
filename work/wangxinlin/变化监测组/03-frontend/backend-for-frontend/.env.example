# 数据库配置：支持外部数据库和 Docker 本地开发切换
# 默认使用外部 PostgreSQL（用户指定）
DATABASE_HOST=your-db-host
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your-password
DATABASE_NAME=postgres

# JWT 密钥
JWT_SECRET=change-monitor-jwt-secret-2026

# 服务端口
PORT=3000

# 如需使用 Docker 本地 PostGIS，请注释上方配置并取消下方注释：
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=change_monitor
# DATABASE_PASSWORD=change_monitor_dev
# DATABASE_NAME=change_monitor
